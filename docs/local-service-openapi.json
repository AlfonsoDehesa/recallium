{
  "openapi": "3.1.0",
  "info": {
    "title": "Recallium Core Local Service API",
    "version": "1",
    "description": "Local-only HTTP JSON service contract for Recallium Core. This slice is localhost-first and intentionally has no authentication. Do not expose this service publicly."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8765",
      "description": "Default local server"
    }
  ],
  "security": [],
  "tags": [
    {
      "name": "service",
      "description": "Local service metadata endpoints"
    },
    {
      "name": "memories",
      "description": "Memory operations"
    }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "tags": ["service"],
        "summary": "Check service health",
        "responses": {
          "200": {
            "description": "Service is reachable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                },
                "example": {
                  "data": {
                    "status": "ok"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/version": {
      "get": {
        "tags": ["service"],
        "summary": "Read service and package version",
        "responses": {
          "200": {
            "description": "Version metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                },
                "example": {
                  "data": {
                    "service_api_version": "1",
                    "recallium_version": "0.x.y"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/capabilities": {
      "get": {
        "tags": ["service"],
        "summary": "Read supported capabilities",
        "responses": {
          "200": {
            "description": "Capability list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/v1/memories/search_user": {
      "post": {
        "tags": ["memories"],
        "summary": "Search user memories",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": { "type": "string" },
                  "limit": { "type": "integer", "minimum": 1, "default": 10 },
                  "include_archived": { "type": "boolean", "default": false }
                },
                "required": ["query"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ranked search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/memories/search_workspace": {
      "post": {
        "tags": ["memories"],
        "summary": "Search workspace memories",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": { "type": "string" },
                  "workspace_uid": { "type": "string" },
                  "limit": { "type": "integer", "minimum": 1, "default": 10 },
                  "include_archived": { "type": "boolean", "default": false }
                },
                "required": ["query", "workspace_uid"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ranked workspace search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/memories": {
      "post": {
        "tags": ["memories"],
        "summary": "Add memory",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "space": { "type": "string", "enum": ["user", "workspace"] },
                  "type": { "type": "string" },
                  "content": { "type": "string" },
                  "workspace_uid": { "type": "string" },
                  "metadata": { "type": "object" },
                  "source": { "type": "string" },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                  "sensitivity": { "type": "string" }
                },
                "required": ["space", "type", "content"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created memory",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      },
      "get": {
        "tags": ["memories"],
        "summary": "List memories",
        "parameters": [
          { "name": "space", "in": "query", "schema": { "type": "string" } },
          { "name": "type", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "workspace_uid", "in": "query", "schema": { "type": "string" } },
          {
            "name": "include_archived",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1 } }
        ],
        "responses": {
          "200": {
            "description": "Filtered memory list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/memories/{memory_id}": {
      "get": {
        "tags": ["memories"],
        "summary": "Get one memory",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      },
      "patch": {
        "tags": ["memories"],
        "summary": "Update one memory",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string" },
                  "type": { "type": "string" },
                  "metadata": { "type": "object" },
                  "source": { "type": "string" },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                  "sensitivity": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated memory",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/memories/{memory_id}/archive": {
      "post": {
        "tags": ["memories"],
        "summary": "Archive one memory",
        "description": "This endpoint is body-less in the current implementation.",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Archived memory",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessEnvelope"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "ErrorResponse": {
        "description": "Error envelope",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      }
    },
    "schemas": {
      "Memory": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "space": { "type": "string" },
          "workspace_uid": { "type": ["string", "null"] },
          "type": { "type": "string" },
          "content": { "type": "string" },
          "metadata": { "type": "object" },
          "status": { "type": "string" },
          "source": { "type": ["string", "null"] },
          "confidence": { "type": ["number", "null"] },
          "sensitivity": { "type": ["string", "null"] },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" },
          "last_accessed_at": { "type": ["string", "null"] }
        },
        "required": [
          "id",
          "space",
          "workspace_uid",
          "type",
          "content",
          "metadata",
          "status",
          "source",
          "confidence",
          "sensitivity",
          "created_at",
          "updated_at",
          "last_accessed_at"
        ]
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "memory": { "$ref": "#/components/schemas/Memory" },
          "score": { "type": "number" },
          "rank": { "type": "integer", "minimum": 1 }
        },
        "required": ["memory", "score", "rank"]
      },
      "SuccessEnvelope": {
        "type": "object",
        "properties": {
          "data": {
            "oneOf": [
              { "$ref": "#/components/schemas/Memory" },
              {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Memory" }
              },
              {
                "type": "array",
                "items": { "$ref": "#/components/schemas/SearchResult" }
              },
              { "type": "object" }
            ]
          }
        },
        "required": ["data"]
      },
      "ErrorEnvelope": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": { "type": "object" }
            },
            "required": ["code", "message", "details"]
          }
        },
        "required": ["error"]
      }
    }
  }
}
